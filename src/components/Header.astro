<header id="header" class="fixed top-0 left-0 right-0 z-50 border-b border-transparent">
  <div class="max-w-6xl mx-auto px-6 h-20 md:h-36 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5 group">
      <img
        src="/logo.png"
        alt="Oriane Annen Public Relations"
        class="h-16 w-auto md:h-28 object-contain"
      />
    </a>

    <nav class="hidden md:flex items-center gap-8 text-sm text-gray-400">
      <a href="/#accueil" class="hover:text-white transition-colors">Accueil</a>
      <a href="/#services" class="hover:text-white transition-colors">Services</a>
      <a href="/#parcours" class="hover:text-white transition-colors">Mon Parcours</a>
      <a href="/#faq" class="hover:text-white transition-colors">FAQ</a>
    </nav>

    <div class="hidden md:flex items-center gap-3">
      <a
        href="https://ch.linkedin.com/in/oriane-annen"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn d'Oriane Annen"
        class="text-violet-400 hover:text-violet-300 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <a
        href="/#contact"
        class="flex items-center gap-2 text-sm font-medium text-white bg-white/5 border border-white/10 px-4 py-2 rounded-lg hover:bg-white/10 transition-colors"
      >
        Me contacter
      </a>
    </div>

    <button id="menu-btn" class="md:hidden text-white relative z-50">
      <iconify-icon icon="solar:hamburger-menu-linear" class="text-2xl block open-icon"></iconify-icon>
      <iconify-icon icon="solar:close-circle-linear" class="text-2xl hidden close-icon"></iconify-icon>
    </button>
  </div>
</header>

<div id="mobile-menu" class="fixed top-0 left-0 w-full h-full z-40 bg-[#090a0c]/98 backdrop-blur-2xl flex flex-col items-center justify-center gap-10 md:hidden opacity-0 pointer-events-none transition-all duration-500">
  <a href="/#accueil" class="text-3xl text-gray-300 hover:text-white transition-colors font-medium" data-menu-link>Accueil</a>
  <a href="/#services" class="text-3xl text-gray-300 hover:text-white transition-colors font-medium" data-menu-link>Services</a>
  <a href="/#parcours" class="text-3xl text-gray-300 hover:text-white transition-colors font-medium" data-menu-link>Mon Parcours</a>
  <a href="/#faq" class="text-3xl text-gray-300 hover:text-white transition-colors font-medium" data-menu-link>FAQ</a>
  <a
    href="https://ch.linkedin.com/in/oriane-annen"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="LinkedIn d'Oriane Annen"
    class="flex items-center gap-2 text-xl text-violet-400 hover:text-violet-300 transition-colors font-medium"
    data-menu-link
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
    LinkedIn
  </a>
  <a href="/#contact" class="mt-4 btn-gradient text-white px-10 py-4 rounded-xl text-base font-medium" data-menu-link>Me contacter</a>
</div>

<script>
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const openIcon = menuBtn?.querySelector('.open-icon');
  const closeIcon = menuBtn?.querySelector('.close-icon');

  function toggleMenu() {
    const isOpen = mobileMenu.classList.contains('open');
    if (isOpen) {
      mobileMenu.classList.remove('open');
      mobileMenu.style.opacity = '0';
      mobileMenu.style.pointerEvents = 'none';
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    } else {
      mobileMenu.classList.add('open');
      mobileMenu.style.opacity = '1';
      mobileMenu.style.pointerEvents = 'auto';
      openIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
    }
  }

  menuBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    toggleMenu();
  });

  mobileMenu?.querySelectorAll('[data-menu-link]').forEach(link => {
    link.addEventListener('click', () => {
      if (mobileMenu.classList.contains('open')) toggleMenu();
    });
  });

  document.addEventListener('click', (e) => {
    if (mobileMenu.classList.contains('open') && !mobileMenu.contains(e.target) && !menuBtn?.contains(e.target)) {
      toggleMenu();
    }
  });
</script>
