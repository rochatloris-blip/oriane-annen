<section id="contact" class="py-24 px-6 section-spacing border-t border-white/5 bg-[#0c0e12]/50">
  <div class="max-w-5xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <!-- Form -->
      <div class="reveal">
        <h2 class="text-3xl font-semibold tracking-tight text-white mb-2">
          Prêt à faire parler de vous ?
        </h2>
        <p class="text-gray-400 text-sm mb-10">
          Remplissez ce formulaire, je vous réponds dans les plus brefs délais avec le sourire.
        </p>

        <form id="contact-form" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="text-[10px] uppercase tracking-widest text-gray-500 font-medium block mb-1">
                Prénom *
              </label>
              <input type="text" name="prenom" required class="input-line w-full text-white text-sm py-2 placeholder-gray-600" placeholder="Jean" />
            </div>
            <div>
              <label class="text-[10px] uppercase tracking-widest text-gray-500 font-medium block mb-1">
                Nom *
              </label>
              <input type="text" name="nom" required class="input-line w-full text-white text-sm py-2 placeholder-gray-600" placeholder="Dupont" />
            </div>
          </div>

          <div>
            <label class="text-[10px] uppercase tracking-widest text-gray-500 font-medium block mb-1">
              Entreprise *
            </label>
            <input type="text" name="entreprise" required class="input-line w-full text-white text-sm py-2 placeholder-gray-600" placeholder="Votre société" />
          </div>

          <div>
            <label class="text-[10px] uppercase tracking-widest text-gray-500 font-medium block mb-1">
              E-mail *
            </label>
            <input type="email" name="email" required class="input-line w-full text-white text-sm py-2 placeholder-gray-600" placeholder="jean@exemple.ch" />
          </div>

          <div>
            <label class="text-[10px] uppercase tracking-widest text-gray-500 font-medium block mb-1">
              Votre demande *
            </label>
            <textarea name="demande" required rows="4" class="input-line w-full text-white text-sm py-2 placeholder-gray-600 resize-none" placeholder="Décrivez brièvement votre projet ou besoin..."></textarea>
          </div>

          <div class="text-[10px] text-gray-500 leading-tight">
            Ce site est protégé par reCAPTCHA et la Politique de confidentialité et les Conditions
            d'utilisation de Google s'appliquent.
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="btn-gradient w-full text-white px-6 py-3.5 rounded-xl text-sm font-medium flex items-center justify-center gap-2"
          >
            Envoyer le message
            <iconify-icon icon="solar:plain-2-linear" class="text-lg"></iconify-icon>
          </button>
        </form>

        <script>
          document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
            e.preventDefault();
            const form = e.target;
            const btn = document.getElementById('submit-btn');
            const data = Object.fromEntries(new FormData(form));

            btn.disabled = true;
            btn.innerHTML = 'Envoi en cours...';

            try {
              const res = await fetch('/contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data),
              });

              if (res.ok) {
                form.reset();
                btn.innerHTML = 'Message envoyé ✓';
                setTimeout(() => {
                  btn.innerHTML = 'Envoyer le message <iconify-icon icon="solar:plain-2-linear" class="text-lg"></iconify-icon>';
                  btn.disabled = false;
                }, 3000);
              } else {
                throw new Error('Erreur');
              }
            } catch {
              btn.innerHTML = 'Erreur — réessaie';
              setTimeout(() => {
                btn.innerHTML = 'Envoyer le message <iconify-icon icon="solar:plain-2-linear" class="text-lg"></iconify-icon>';
                btn.disabled = false;
              }, 3000);
            }
          });
        </script>
      </div>

      <!-- Info Sidebar -->
      <div class="reveal lg:pl-12 lg:border-l border-white/5 flex flex-col justify-center">
        <div class="glass-card rounded-2xl p-8">
          <h3 class="text-lg font-medium text-white tracking-tight mb-8">Coordonnées</h3>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div
                class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-violet-400 shrink-0"
              >
                <iconify-icon icon="solar:map-point-linear" class="text-xl"></iconify-icon>
              </div>
              <div>
                <p class="text-xs text-gray-500 uppercase tracking-widest font-medium mb-1">Adresse</p>
                <p class="text-sm text-gray-300">
                  Oriane Annen<br />
                  Vy d'Echallens 1M<br />
                  1004 Lausanne
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div
                class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-violet-400 shrink-0"
              >
                <iconify-icon icon="solar:letter-linear" class="text-xl"></iconify-icon>
              </div>
              <div>
                <p class="text-xs text-gray-500 uppercase tracking-widest font-medium mb-1">E-mail</p>
                <a
                  href="mailto:oriane.annen03@gmail.com"
                  class="text-sm text-gray-300 hover:text-white transition-colors"
                >
                  oriane.annen03@gmail.com
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div
                class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-violet-400 shrink-0"
              >
                <iconify-icon icon="solar:hashtag-linear" class="text-xl"></iconify-icon>
              </div>
              <div>
                <p class="text-xs text-gray-500 uppercase tracking-widest font-medium mb-1">Réseaux</p>
                <a
                  href="https://ch.linkedin.com/in/oriane-annen"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-gray-300 hover:text-white transition-colors flex items-center gap-1"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  LinkedIn
                  <iconify-icon icon="solar:arrow-right-up-linear"></iconify-icon>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
