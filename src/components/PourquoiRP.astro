<section class="pt-12 pb-24 md:pt-14 md:pb-24 section-spacing px-6 relative z-10">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="reveal flex flex-col gap-8 order-2 lg:order-1">
        <span class="text-xs font-semibold tracking-widest text-violet-400 uppercase">
          Pourquoi les RP ?
        </span>
        <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-white leading-tight">
          Quand un tiers de confiance parle de vous, tout change.
        </h2>
        <p class="text-gray-400 text-base leading-relaxed">
          Quand un journal, une radio ou un podcast parle de vous, ce n'est plus vous qui dites que
          vous êtes bon — c'est un leader d'opinion, un journaliste, un média.
        </p>

        <div class="glass-card rounded-2xl p-6 border-l-2 border-l-violet-500 relative overflow-hidden">
          <div class="absolute -right-10 -top-10 w-40 h-40 bg-violet-500/10 blur-3xl rounded-full"></div>
          <div class="flex items-center gap-4 mb-2 relative z-10">
            <div class="w-10 h-10 rounded-full bg-violet-500/10 flex items-center justify-center text-violet-400">
              <iconify-icon icon="solar:wallet-linear" class="text-xl"></iconify-icon>
            </div>
            <div>
              <h3 class="text-sm font-medium text-white tracking-tight">Accessible</h3>
              <p class="text-xs text-gray-400">Pour indépendants et PME</p>
            </div>
          </div>
          <p class="text-lg font-medium text-white tracking-tight mt-4 relative z-10">
            Dès 80 CHF — sans contrat annuel, sans budget d'agence.
          </p>
        </div>
      </div>

      <div class="reveal order-1 lg:order-2">
        <div
          class="glass-card rounded-3xl p-10 md:p-14 relative overflow-hidden text-center shadow-[0_0_50px_rgba(139,92,246,0.05)]"
        >
          <div class="absolute inset-0 bg-gradient-to-br from-violet-400/5 to-violet-500/5"></div>
          <iconify-icon
            icon="solar:quote-left-linear"
            class="text-4xl text-violet-500/40 mx-auto mb-6 block relative z-10"
          ></iconify-icon>
          <div id="typewriter-root" class="text-2xl md:text-3xl font-medium tracking-tight text-white leading-snug relative z-10 typewriter-container">
            <p class="text-gradient typewriter-line">"Les réseaux vous rendent visible.</p>
            <p class="text-gradient typewriter-line">La pub vous rend connu.</p>
            <p class="text-gradient typewriter-line">Les médias vous rendent crédible."</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const root = document.getElementById('typewriter-root');
    if (!root || prefersReduced) return;

    const texts = [
      'Les réseaux vous rendent visible.',
      'La pub vous rend connu.',
      'Les médias vous rendent crédible.',
    ];

    let lineIdx = 0;
    let charIdx = 0;
    let currentP = null;
    const cursor = document.createElement('span');
    cursor.className = 'typewriter-cursor';
    cursor.textContent = '|';

    function type() {
      if (lineIdx >= texts.length) { cursor.style.display = 'none'; return; }

      if (charIdx === 0) {
        currentP = document.createElement('p');
        currentP.className = 'typewriter-line text-gradient';
        root.insertBefore(currentP, cursor);
      }

      if (charIdx < texts[lineIdx].length) {
        currentP.textContent += texts[lineIdx][charIdx++];
        setTimeout(type, 45);
      } else {
        lineIdx++;
        charIdx = 0;
        if (lineIdx < texts.length) {
          setTimeout(type, 200);
        }
      }
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          root.innerHTML = '';
          root.appendChild(cursor);
          type();
          observer.disconnect();
        }
      });
    }, { threshold: 0.5 });

    observer.observe(root);
  })();
</script>
